/* 1. THE FLOW PROTECTOR */
/* Forces every module to respect the boundaries of others */
.et_pb_section, .et_pb_row, .et_pb_column, .et_pb_module {
    position: relative !important; 
    top: auto !important;
    bottom: auto !important;
    transform: none !important; /* Kills 'ghost' overlaps from absolute centering */
    height: auto !important;    /* Prevents containers from cutting off text */
    min-height: 0 !important;
}

/* 2. ULTRAWIDE PROTECTION (Screens wider than 1600px) */
/* Prevents your header/content from flying to the far edges */
@media (min-width: 1600px) {
    .et_pb_row, .et_pb_section > .et_pb_container {
        max-width: 1440px !important; 
        margin-left: auto !important;
        margin-right: auto !important;
        width: 90% !important;
    }
}

/* 3. TABLET & MOBILE FIX (Screens smaller than 980px) */
/* Forces side-by-side elements to stack vertically so they don't squish */
@media (max-width: 980px) {
    .et_pb_row {
        display: flex !important;
        flex-direction: column !important;
        width: 95% !important;
        padding: 10px 0 !important;
    }

    .et_pb_column {
        width: 100% !important;
        max-width: 100% !important;
        margin-bottom: 20px !important; /* Safety gap so items don't touch */
    }

    /* Fixes distorted images and code modules */
    .et_pb_module img, .et_pb_code_wrapper {
        max-width: 100% !important;
        height: auto !important;
    }
}

/* 4. ANTI-WOBBLE */
/* Prevents horizontal scrolling on phones */
html, body {
    overflow-x: hidden !important;
    width: 100%;
}
